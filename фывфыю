version: "3.9"

services:
  # ─── PostgreSQL ───────────────────────────────────────────────────────────────
  postgres:
    image: postgres:16-alpine
    container_name: sm_postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${DB_NAME:-studentmarketplace}
      POSTGRES_USER: ${DB_USER:-smuser}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - sm_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-smuser}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ─── Redis ────────────────────────────────────────────────────────────────────
  redis:
    image: redis:7-alpine
    container_name: sm_redis
    restart: unless-stopped
    command: redis-server --requirepass ${REDIS_PASSWORD} --maxmemory 256mb --maxmemory-policy allkeys-lru
    volumes:
      - redis_data:/data
    networks:
      - sm_network
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${REDIS_PASSWORD}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ─── MinIO ────────────────────────────────────────────────────────────────────
  minio:
    image: minio/minio:latest
    container_name: sm_minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: ${MINIO_USER:-minioadmin}
      MINIO_ROOT_PASSWORD: ${MINIO_PASSWORD}
    volumes:
      - minio_data:/data
    networks:
      - sm_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 10s
      retries: 3

  # ─── Backend API ──────────────────────────────────────────────────────────────
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: sm_backend
    restart: unless-stopped
    environment:
      - APP_ENV=production
      - APP_PORT=8080
      - FRONTEND_URL=https://404tears.kz
      - DB_HOST=postgres
      - DB_PORT=5432
      - DB_NAME=${DB_NAME:-studentmarketplace}
      - DB_USER=${DB_USER:-smuser}
      - DB_PASSWORD=${DB_PASSWORD}
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=${REDIS_PASSWORD}
      - JWT_ACCESS_SECRET=${JWT_ACCESS_SECRET}
      - JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
      - JWT_ACCESS_EXPIRE=${JWT_ACCESS_EXPIRE:-15m}
      - JWT_REFRESH_EXPIRE=${JWT_REFRESH_EXPIRE:-720h}
      - MINIO_ENDPOINT=minio:9000
      - MINIO_USER=${MINIO_USER:-minioadmin}
      - MINIO_PASSWORD=${MINIO_PASSWORD}
      - MINIO_BUCKET=${MINIO_BUCKET:-student-marketplace}
      - MINIO_USE_SSL=false
      - MINIO_PUBLIC_URL=https://404tears.kz/minio
      - SMTP_HOST=${SMTP_HOST:-smtp.gmail.com}
      - SMTP_PORT=${SMTP_PORT:-587}
      - SMTP_USER=${SMTP_USER}
      - SMTP_PASS=${SMTP_PASS}
      - GOOGLE_CLIENT_ID_WEB=${GOOGLE_CLIENT_ID_WEB}
      - GOOGLE_CLIENT_SECRET_WEB=${GOOGLE_CLIENT_SECRET_WEB}
      - GOOGLE_CALLBACK_URL=https://404tears.kz/api/v1/auth/google/callback
      - PLATFORM_FEE_PERCENT=${PLATFORM_FEE_PERCENT:-10}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      minio:
        condition: service_healthy
    networks:
      - sm_network
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8080/health"]
      interval: 30s
      timeout: 5s
      retries: 3

  # ─── Frontend ─────────────────────────────────────────────────────────────────
  # frontend:
  #   build:
  #     context: ./frontend
  #     dockerfile: Dockerfile
  #     args:
  #       - VITE_API_URL=https://404tears.kz
  #       - VITE_WS_URL=wss://404tears.kz
  #   container_name: sm_frontend
  #   restart: unless-stopped
  #   networks:
  #     - sm_network

  # ─── Nginx ────────────────────────────────────────────────────────────────────
  nginx:
    image: nginx:alpine
    container_name: sm_nginx
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - letsencrypt:/etc/letsencrypt:ro
      - certbot_webroot:/var/www/certbot:ro
    depends_on:
      - backend
    networks:
      - sm_network

  # ─── Certbot (Let's Encrypt) ──────────────────────────────────────────────────
  certbot:
    image: certbot/certbot:latest
    container_name: sm_certbot
    volumes:
      - letsencrypt:/etc/letsencrypt
      - certbot_webroot:/var/www/certbot
    entrypoint: >
      sh -c "trap exit TERM;
             while :; do
               certbot renew --webroot -w /var/www/certbot --quiet;
               sleep 12h & wait $${!};
             done"
    networks:
      - sm_network

volumes:
  postgres_data:
  redis_data:
  minio_data:
  letsencrypt:
  certbot_webroot:

networks:
  sm_network:
    driver: bridge
